# ============================================================
# EldonOpenClaw — .env.example
# Copy to .env and fill in real values. NEVER commit .env.
# ============================================================

# ── LLM ────────────────────────────────────────────────────
# Required: the chat model your LLM provider serves
OPENCLAW_CHAT_MODEL=YOUR_CHAT_MODEL

# Optional: only needed if memory/vector features are enabled
OPENCLAW_EMBED_MODEL=

# Provider API key (OpenAI-compatible endpoint assumed)
OPENAI_API_KEY=YOUR_OPENAI_API_KEY

# Optional: override the base URL for self-hosted / local LLMs
# OPENAI_BASE_URL=http://localhost:11434/v1

# ── APP ────────────────────────────────────────────────────
OPENCLAW_ENV=development
OPENCLAW_LOG_LEVEL=info

# ── CONNECTORS ─────────────────────────────────────────────
# Enable the connectors you want (true/false)
OPENCLAW_CONNECTOR_CLI=true
OPENCLAW_CONNECTOR_TELEGRAM=false
OPENCLAW_CONNECTOR_VOICE=false

# Telegram bot token — required only if CONNECTOR_TELEGRAM=true
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN

# ── MEMORY ─────────────────────────────────────────────────
# Set to true only if OPENCLAW_EMBED_MODEL is also set
OPENCLAW_MEMORY_ENABLED=false
OPENCLAW_VECTOR_STORE=local
OPENCLAW_VECTOR_STORE_PATH=.data/vector_store

# ── ACTION GATING ──────────────────────────────────────────
# Require explicit confirmation before destructive actions
OPENCLAW_ACTION_CONFIRM=true
