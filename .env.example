# ============================================================
# OpenClaw secrets — copy to .env, never commit .env
# ============================================================

# LLM provider keys (leave empty if provider = "none")
OPENAI_API_KEY=

# Telegram connector (leave empty if telegram disabled)
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_CHAT_IDS=   # comma-separated, e.g. 123456,789012

# Storage
SQLITE_PATH=./data/openclaw.db
