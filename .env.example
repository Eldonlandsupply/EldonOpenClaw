# ============================================================
# EldonOpenClaw — .env.example
# Copy to .env and fill in real values. NEVER commit .env.
# ============================================================

# ── LLM ────────────────────────────────────────────────────
# Set provider in config.yaml: openai | openrouter | anthropic | none

# OpenAI — required if llm.provider=openai
OPENAI_API_KEY=

# OpenRouter — required if llm.provider=openrouter
OPENROUTER_API_KEY=

# ── STORAGE ────────────────────────────────────────────────
SQLITE_PATH=./data/openclaw.db

# ── EMAIL / NOTIFICATIONS ──────────────────────────────────
# Gmail SMTP (app password, not your account password)
GMAIL_USER=
GMAIL_APP_PASSWORD=

# Who receives alert notifications
NOTIFICATION_EMAIL=

# ── TELEGRAM ───────────────────────────────────────────────
# Required only if connectors.telegram.enabled=true in config.yaml
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_CHAT_IDS=

# ── AZURE / MICROSOFT GRAPH ────────────────────────────────
# Required only if using Outlook email connector
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
