# ============================================================
# EldonOpenClaw — .env.example
# Copy to .env and fill in real values. NEVER commit .env.
# ============================================================

# ── LLM (OpenRouter) ───────────────────────────────────────
# OpenRouter is the default provider — it supports 200+ models
# via a single OpenAI-compatible endpoint.
OPENROUTER_API_KEY=YOUR_OPENROUTER_KEY

# Model to use. Recommended:
#   anthropic/claude-3-haiku     (fast, cheap)
#   anthropic/claude-3.5-sonnet  (more capable)
#   openai/gpt-4o-mini           (OpenAI via OpenRouter)
OPENCLAW_CHAT_MODEL=anthropic/claude-3-haiku

# Optional: only needed if memory/vector features are enabled
OPENCLAW_EMBED_MODEL=

# ── APP ────────────────────────────────────────────────────
OPENCLAW_ENV=production
OPENCLAW_LOG_LEVEL=info

# ── CONNECTORS ─────────────────────────────────────────────
OPENCLAW_CONNECTOR_CLI=true
OPENCLAW_CONNECTOR_TELEGRAM=false
OPENCLAW_CONNECTOR_VOICE=false

# Telegram bot token — required only if CONNECTOR_TELEGRAM=true
TELEGRAM_BOT_TOKEN=

# ── MEMORY ─────────────────────────────────────────────────
OPENCLAW_MEMORY_ENABLED=false
OPENCLAW_VECTOR_STORE=local
OPENCLAW_VECTOR_STORE_PATH=.data/vector_store

# ── ACTION GATING ──────────────────────────────────────────
OPENCLAW_ACTION_CONFIRM=true

# ── EMAIL (optional) ───────────────────────────────────────
# Gmail
GMAIL_USER=
GMAIL_APP_PASSWORD=

# Outlook / Microsoft Graph
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
