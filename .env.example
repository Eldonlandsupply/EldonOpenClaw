# ============================================================
# EldonOpenClaw — .env.example
# Copy to .env and fill in real values. NEVER commit .env.
# ============================================================

# ── LLM PROVIDER ───────────────────────────────────────────
# Options: openrouter | openai | anthropic | none
LLM_PROVIDER=openrouter

# Model id — for OpenRouter use "provider/model" format
# Examples:
#   openai/gpt-4o-mini   (fast, cheap)
#   openai/gpt-4o        (more capable)
#   anthropic/claude-3-haiku-20240307
LLM_CHAT_MODEL=openai/gpt-4o-mini

# ── API KEYS ───────────────────────────────────────────────
# OpenRouter — required if OPENCLAW_LLM_PROVIDER=openrouter
OPENROUTER_API_KEY=

# OpenAI — required if OPENCLAW_LLM_PROVIDER=openai
OPENAI_API_KEY=

# ── STORAGE ────────────────────────────────────────────────
SQLITE_PATH=./data/openclaw.db

# ── EMAIL / NOTIFICATIONS ──────────────────────────────────
# Gmail SMTP (app password, not your account password)
GMAIL_USER=
GMAIL_APP_PASSWORD=

# Who receives alert notifications
NOTIFICATION_EMAIL=

# ── TELEGRAM ───────────────────────────────────────────────
# Required only if connectors.telegram.enabled=true in config.yaml
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_CHAT_IDS=

# ── AZURE / MICROSOFT GRAPH ────────────────────────────────
# Required only if using Outlook email connector
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# ── RUNTIME OVERRIDES (optional) ───────────────────────────
# OPENCLAW_DRY_RUN=false
# OPENCLAW_LOG_LEVEL=INFO
