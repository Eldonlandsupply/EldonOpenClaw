# ============================================================
# EldonOpenClaw — .env.example
# Copy to .env and fill in real values. NEVER commit .env.
# ============================================================

# ── LLM (OpenRouter) ───────────────────────────────────────
OPENROUTER_API_KEY=YOUR_OPENROUTER_KEY
OPENCLAW_CHAT_MODEL=openai/gpt-4o-mini
OPENCLAW_EMBED_MODEL=

# ── APP ────────────────────────────────────────────────────
OPENCLAW_ENV=production
OPENCLAW_LOG_LEVEL=info

# ── CONNECTORS ─────────────────────────────────────────────
OPENCLAW_CONNECTOR_CLI=true
OPENCLAW_CONNECTOR_TELEGRAM=false
OPENCLAW_CONNECTOR_VOICE=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_CHAT_IDS=

# ── MEMORY ─────────────────────────────────────────────────
OPENCLAW_MEMORY_ENABLED=false
OPENCLAW_VECTOR_STORE=local
OPENCLAW_VECTOR_STORE_PATH=.data/vector_store

# ── ACTION GATING ──────────────────────────────────────────
OPENCLAW_ACTION_CONFIRM=true

# ── EMAIL ──────────────────────────────────────────────────
GMAIL_USER=
GMAIL_APP_PASSWORD=
NOTIFICATION_EMAIL=

# ── OUTLOOK / MICROSOFT GRAPH ──────────────────────────────
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

